Options -Indexes

<FilesMatch "^(\.env|\.deployignore|composer\.(json|lock)|package(-lock)?\.json|README\.md|.*\.(sql|zip|bak|backup|old|log|tex))$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule (^|/)\.(git|codex|agents)(/|$) - [F,L]
    RewriteRule ^(config|database|docs)(/|$) - [F,L]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
